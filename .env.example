# Environment Configuration
# Copy this file to .env and fill in your credentials

# Server Configuration
PORT=3000

# Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_API_KEY_2=your_second_key_here
# GEMINI_API_KEY_3=your_third_key_here
GEMINI_REQUEST_TIMEOUT=30000

# Session Secret for auth
SESSION_SECRET=your_session_secret_here

# Redis connection (used by BullMQ for receipt processing queue)
REDIS_URL=redis://localhost:6379

# Supabase (PostgreSQL multi-tenant backend)
# Get these from https://supabase.com dashboard → Settings → API
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
